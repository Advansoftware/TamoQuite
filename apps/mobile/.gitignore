# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ---- Signing secrets — NEVER commit these ----
# key.properties holds the release keystore passwords; the keystore itself is the
# single credential that lets anyone publish an update to app.tamoquite.mobile.
/android/key.properties
*.jks
*.keystore
/ios/Runner/GoogleService-Info.plist
/android/app/google-services.json

# Local environment overrides
.env
.env.*
!.env.example

# Generated / local Flutter tooling
.flutter-plugins
/android/.gradle/
/android/local.properties
/ios/Pods/
/ios/.symlinks/

# The repo root ignores `test/` (a Node-era rule). Flutter's test suite lives in
# apps/mobile/test and must stay versioned — this negation restores it.
!test/
