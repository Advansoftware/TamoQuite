generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SystemUser {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  passwordHash     String
  role             String       @default("CLIENT")
  mustChangePassword Boolean     @default(true)
  isActive         Boolean      @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId  String?
  subscriptionStatus   String?      @default("INACTIVE")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  borrowers        Borrower[]
  loans            Loan[]
  createdBy        String?
  createdByUser    SystemUser?  @relation("UserHierarchy", fields: [createdBy], references: [id])
  createdUsers     SystemUser[] @relation("UserHierarchy")
}

model Borrower {
  id        String     @id @default(cuid())
  userId    String
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  loans     Loan[]
}

model Loan {
  id               String     @id @default(cuid())
  userId           String
  user             SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowerId       String
  borrower         Borrower   @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  originalAmount   Float
  interestRate     Float
  totalAmount      Float
  installmentCount Int
  startDate        DateTime
  status           String     @default("ACTIVE")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  installments     Installment[]
}

model Installment {
  id                String    @id @default(cuid())
  loanId            String
  loan              Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  status            String    @default("PENDING")
  paidAmount        Float     @default(0)
  paidAt            DateTime?
  type              String    @default("ORIGINAL")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  partialPayments   PartialPayment[]
}

model PartialPayment {
  id            String    @id @default(cuid())
  installmentId String
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  amount        Float
  note          String?
  createdAt     DateTime  @default(now())
}