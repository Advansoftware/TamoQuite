generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SystemUser {
  id                   String       @id @default(cuid())
  email                String       @unique
  name                 String
  passwordHash         String
  role                 String       @default("CLIENT")
  mustChangePassword   Boolean      @default(true)
  isActive             Boolean      @default(true)
  deactivatedAt        DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?      @default("INACTIVE")
  trialUsedAt          DateTime?    // marca que o cliente já usou os 7 dias grátis (1 trial por cliente)
  notifyBeforeSubExpiryDays Int     @default(2) // avisar N dias antes da assinatura vencer/renovar
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  borrowers            Borrower[]
  loans                Loan[]
  createdBy            String?
  createdByUser        SystemUser?  @relation("UserHierarchy", fields: [createdBy], references: [id])
  createdUsers         SystemUser[] @relation("UserHierarchy")

  whatsappInstance     WhatsappInstance?
  billingSettings      BillingSettings?
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String     @id @default(cuid())
  userId    String
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String     @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())

  @@index([userId])
}

model Borrower {
  id        String     @id @default(cuid())
  userId    String
  user      SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String
  notes     String?    @db.Text
  // Soft delete: nothing is ever removed from the system, only deactivated.
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  loans     Loan[]

  @@index([userId])
  @@index([userId, isActive])
}

model Loan {
  id               String     @id @default(cuid())
  userId           String
  user             SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowerId       String
  borrower         Borrower   @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  originalAmount   Float
  interestRate     Float
  totalAmount      Float
  installmentCount Int
  startDate        DateTime
  paymentFrequency String     @default("MONTHLY") // WEEKLY | BIWEEKLY | MONTHLY
  status           String     @default("ACTIVE") // ACTIVE | COMPLETED | CANCELED
  canceledAt       DateTime?
  // Soft delete. Once set, the contract and everything hanging off it
  // (parcelas, cobranças, link público) are invisible to the whole app — no
  // listing, no totals, no charging. The rows survive only for auditing.
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  installments     Installment[]
  share            LoanShare?

  // Billing / cobrança
  doNotCharge         Boolean  @default(false)
  billingOverride     Boolean  @default(false)
  whatsappMode        String?  // null = herda do usuário. MANUAL | OWN | GLOBAL
  remindBeforeEnabled Boolean?
  daysBefore          Int?
  sendOnDueDate       Boolean?
  overdueEnabled      Boolean?
  overdueIntervalDays Int?

  @@index([userId])
  @@index([borrowerId])
  @@index([userId, deletedAt])
}

model Installment {
  id                String    @id @default(cuid())
  loanId            String
  loan              Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  status            String    @default("PENDING")
  paidAmount        Float     @default(0)
  paidAt            DateTime?
  type              String    @default("ORIGINAL")
  doNotCharge       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  partialPayments   PartialPayment[]
  chargeLogs        ChargeLog[]

  @@index([loanId])
  @@index([dueDate])
}

model PartialPayment {
  id            String      @id @default(cuid())
  installmentId String
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  amount        Float
  note          String?     @db.Text
  createdAt     DateTime    @default(now())

  @@index([installmentId])
}

model WhatsappInstance {
  id              String     @id @default(cuid())
  userId          String     @unique
  user            SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName    String     @unique
  status          String     @default("DISCONNECTED") // DISCONNECTED | CONNECTING | CONNECTED
  connectedNumber String?
  lastConnectedAt DateTime?
  lastSentAt      DateTime?  // usado pelo worker para throttle (rate limit por instância)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// Pool de números gerenciados pelo admin — usados no modo GLOBAL.
model GlobalWhatsappInstance {
  id              String    @id @default(cuid())
  instanceName    String    @unique
  label           String?
  status          String    @default("DISCONNECTED") // DISCONNECTED | CONNECTING | CONNECTED
  connectedNumber String?
  isActive        Boolean   @default(true)
  ratePerMinute   Int       @default(8)   // teto de envios por minuto (anti-ban)
  dailyCap        Int       @default(500) // teto por dia (0 = ilimitado)
  sentToday       Int       @default(0)
  dayAnchor       DateTime  @default(now())
  lastSentAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Fila de saída — o cron enfileira; o worker drena com throttle.
model OutboundMessage {
  id            String    @id @default(cuid())
  userId        String
  phone         String
  message       String    @db.Text
  mode          String    // OWN | GLOBAL
  purpose       String    @default("BILLING") // BILLING | AUTOREPLY
  chargeLogId   String?
  instanceName  String?
  status        String    @default("PENDING") // PENDING | SENDING | SENT | FAILED | CANCELED
  attempts      Int       @default(0)
  scheduledFor  DateTime  @default(now())
  sentAt        DateTime?
  error         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([status, scheduledFor])
  @@index([userId])
}

model BillingSettings {
  id                  String     @id @default(cuid())
  userId              String     @unique
  user                SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappMode        String     @default("OWN") // MANUAL | OWN | GLOBAL
  contactPhone        String?    // {{telefone_credor}} nos templates globais
  remindBeforeEnabled Boolean    @default(true)
  daysBefore          Int        @default(3)
  sendOnDueDate       Boolean    @default(true)
  overdueEnabled      Boolean    @default(true)
  overdueIntervalDays Int        @default(3)
  maxOverdueMessages  Int        @default(0) // 0 = ilimitado
  sendHour            Int        @default(9) // hora local (America/Sao_Paulo) de envio
  reminderTemplate    String     @db.Text
  dueTemplate         String     @db.Text
  overdueTemplate     String     @db.Text
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

/// Public, read-only link to a contract. The token is the only credential, so it
/// is generated from crypto random bytes — never derived from the loan id.
/// Revoking sets `revokedAt` (the row stays, like everything else in the system);
/// a new link for the same contract reuses this row with a fresh token.
model LoanShare {
  id           String    @id @default(cuid())
  loanId       String    @unique
  loan         Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  token        String    @unique
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?

  @@index([token])
}

model ChargeLog {
  id                 String      @id @default(cuid())
  installmentId      String
  installment        Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  type               String // REMINDER | DUE | OVERDUE | MANUAL
  status             String // QUEUED | SENT | FAILED
  message            String      @db.Text
  evolutionMessageId String?
  error              String?     @db.Text
  sentAt             DateTime    @default(now())
  // Delivery receipts from WhatsApp (MESSAGES_UPDATE webhook). `status: SENT`
  // only means WhatsApp accepted the message — these say it actually landed.
  deliveryStatus     String? // DELIVERED | READ
  deliveredAt        DateTime?
  readAt             DateTime?

  @@index([installmentId, type, sentAt])
  @@index([evolutionMessageId])
  @@index([sentAt])
}
