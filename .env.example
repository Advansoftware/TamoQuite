# =========================================================================
# TamoQuite — variáveis do stack Docker (docker-compose / Coolify)
# Copie para .env e ajuste. No Coolify, defina estas como variáveis do serviço.
# =========================================================================

# ---- MySQL ----
MYSQL_DATABASE=tamoquite
MYSQL_USER=tamoquite
MYSQL_PASSWORD=troque-esta-senha
MYSQL_ROOT_PASSWORD=troque-esta-senha-root

# ---- Timezone (usado pelo cron de cobrança) ----
TZ=America/Sao_Paulo

# ---- API (NestJS) ----
JWT_SECRET=troque-por-um-segredo-forte
# Origem(ns) do frontend liberada(s) no CORS (separe por vírgula).
# Em produção use o domínio público do app (ex.: https://app.seudominio.com)
WEB_ORIGIN=http://localhost:3000

# ---- Frontend (Next.js) ----
# URL pública onde a API responde (navegador + futuro app mobile).
# Em produção use o domínio público da API (ex.: https://api.seudominio.com)
NEXT_PUBLIC_API_URL=http://localhost:3042

# ---- Portas: SOMENTE dev local (docker-compose.override.yml) ----
# Em produção NÃO são usadas — o proxy do Coolify roteia pelos domínios.
API_PORT=3042
WEB_PORT=3000

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_1Tj2ZQCsywhPRDWax02I6aMH

# ---- Evolution API (WhatsApp) ----
# Instância externa; o usuário final apenas conecta/desconecta o celular dele.
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=
